          "language" : "sql",
          "content" : "select * from \r (select /*+  parallel(wrk)  parallel(account_history) parallel(account_alias) use_hash(wrk account_history account_alias) */\r \taccount_alias.accid accid_account_alias,\r     wrk.application_store_number as application_store_number_src,\r     case when wrk.application_status = 'CANCELLED' then 'CA'\r \t\t when wrk.application_status = 'APPROVED' then 'AP'\r \t\t when wrk.application_status = 'ABORTED' then 'AX'\r \t\t when wrk.application_status = 'PRODUCT_ONBOARDING_COMPLETED' then 'AF'\r \t\t when wrk.application_status = 'REFERRED' then 'RF'\r \t\t when wrk.application_status = 'DECLINED' then 'DE'\r      end as status_src,\r \t wrk.last_action_date as status_date_src,\r \taccount_history.accid as accid_tgt,\r \taccount_history.domicile_branch as domicile_branch_tgt, \r \taccount_history.status as status_tgt,\r \taccount_history.status_date as status_date_tgt,\r \taccount_history.efrom,\r     row_number() over (partition by wrk.application_number order by wrk.last_action_date desc) row_number\r from  work_cards_orig_staging wrk, \r \t  account_history partition(hot),\r \t  account_alias\r where \r       wrk.application_number = account_alias.account_alias_id\r and   account_alias.accid = account_history.accid (+)\r and   account_alias.source_system_code = 'U'\r and   account_alias.class ='563'\r and   account_alias.eto is null\r and   account_history.eto (+) is null)\r where row_number = 1"
        } ]
