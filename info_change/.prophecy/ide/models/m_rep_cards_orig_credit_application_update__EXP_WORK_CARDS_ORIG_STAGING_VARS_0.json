    "SQ_WORK_CARDS_ORIG_STAGING" : {
      "id" : "SQ_WORK_CARDS_ORIG_STAGING",
      "component" : "SQLStatement",
      "metadata" : {
        "label" : "SQ_WORK_CARDS_ORIG_STAGING",
        "x" : 20,
        "y" : 420,
        "phase" : 1
      },
      "properties" : {
        "fileTabs" : [ {
          "path" : "out0",
          "id" : "out0",
          "language" : "sql",
          "content" : "SELECT  /*+ parallel(src_final) parallel(tgt) use_hash(src_final tgt) */\r     src_final.*,\r     tgt.accid AS accid_tgt,\r     tgt.initial_decision_coarse_tgt,\r     tgt.initial_decision_primary_tgt,\r     tgt.final_decision_coarse_tgt,\r     tgt.final_decision_primary_tgt,\r     tgt.efrom AS efrom_tgt,\r     tgt.action_date AS action_date_tgt\r FROM\r     (\r         SELECT  /*+ parallel(aa) parallel(src) use_hash(aa src) */\r             aa.accid AS accid_src,\r             src.*\r         FROM\r             (\r                 SELECT\r                     wrk.*,\r                     wrk_initial.initial_application_status AS initial_application_status_src,\r                     wrk_final.final_application_status AS final_application_status_src\r                 FROM\r                     (\r                         SELECT\r                             wrk_temp.*\r                         FROM\r                             (\r                                 SELECT\r                                     application_number AS application_number,\r                                     application_status AS application_status,\r                                     employment_status,\r                                     cdd_result,\r                                     rts_transaction_status,\r                                     identity_verification_status,\r                                     fraud_result,\r                                     credit_decision_result,\r                                     marital_status,\r                                     application_store_number,\r                                     application_date,\r                                     substr(\r                                         account_number,\r                                         -10\r                                     ),\r                                     product,\r                                     application_source_code,\r                                     application_score,\r                                     ciiscore,\r                                     delphi_score,\r                                     first_party_fraud_score,\r                                     credit_decision_annual_percentage_rate,\r                                     residential_status,\r                                     annual_income_amount,\r                                     residential_moved_in_date,\r                                     previous_addresses_moved_in_date,\r                                     occupation,\r                                     employment_main_startdate,\r                                     credit_decision_final_credit_limit_offer,\r                                     offered_limit_amount,\r                                     annual_salary_amount,\r                                     offer_id,\r                                     customer_number,\r                                     employment_role,\r                                     product_number,\r                                     number_of_dependents,\r                                     credit_requested_amount,\r                                     email,\r                                     marketing_preferences_preferred_channels,\r                                     postcode,\r                                     date_of_birth,\r                                     foresee_changes_to_personal_circumstances,\r                                     last_action_date AS last_action_date_max,\r                                     substr(\r                                         TO_CHAR(last_action_date),\r                                         11,\r                                         2\r                                     )\r                                      || substr(\r                                         TO_CHAR(last_action_date),\r                                         14,\r                                         2\r                                     )\r                                      || substr(\r                                         TO_CHAR(last_action_date),\r                                         17,\r                                         2\r                                     ) AS time_stamp_of_action,\r                                     ROW_NUMBER() OVER(PARTITION BY\r                                         wrk.application_number\r                                         ORDER BY\r                                             last_action_date\r                                         DESC\r                                     ) row_num\r                                 FROM\r                                     work_cards_orig_staging wrk\r                             ) wrk_temp\r                         WHERE\r                             wrk_temp.row_num = 1\r                     ) wrk,\r                     (\r                         SELECT DISTINCT\r                             application_number,\r                             application_status AS initial_application_status\r                         FROM\r                             work_cards_orig_staging\r                         WHERE\r                             ( application_number,last_action_date ) IN (\r                                 SELECT\r                                     application_number,\r                                     MIN(last_action_date)\r                                 FROM\r                                     work_cards_orig_staging\r                                 WHERE\r                                     application_status != 'PRODUCT_ONBOARDING_COMPLETED'\r                                 GROUP BY\r                                     application_number\r                             )\r                     ) wrk_initial,\r                     (\r                         SELECT DISTINCT\r                             application_number,\r                             application_status AS final_application_status\r                         FROM\r                             work_cards_orig_staging\r                         WHERE\r                             ( application_number,last_action_date ) IN (\r                                 SELECT\r                                     application_number,\r                                     MAX(last_action_date)\r                                 FROM\r                                     work_cards_orig_staging\r                                 WHERE\r                                     application_status != 'PRODUCT_ONBOARDING_COMPLETED'\r                                 GROUP BY\r                                     application_number\r                             )\r                     ) wrk_final\r                 WHERE\r                         wrk.application_number = wrk_initial.application_number (+)\r                     AND\r                         wrk.application_number = wrk_final.application_number (+)\r             ) src,\r             account_alias aa\r         WHERE\r                 aa.account_alias_id = src.application_number\r             AND\r                 aa.eto IS NULL\r             AND\r                 aa.class = '563'\r     ) src_final,\r     (\r         SELECT   /* parallel(tgt) */\r             accid,\r             tgt.initial_decision_coarse AS initial_decision_coarse_tgt,\r             tgt.initial_decision_primary AS initial_decision_primary_tgt,\r             tgt.final_decision_coarse AS final_decision_coarse_tgt,\r             tgt.final_decision_primary AS final_decision_primary_tgt,\r             tgt.efrom,\r             action_date\r         FROM\r             credit_application tgt\r         WHERE\r             eto IS NULL\r     ) tgt\r WHERE\r     src_final.accid_src = tgt.accid (+)"
        } ]
      },
