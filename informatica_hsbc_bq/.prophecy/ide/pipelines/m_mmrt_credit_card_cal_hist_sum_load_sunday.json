      "properties" : {
        "fileTabs" : [ {
          "path" : "out0",
          "id" : "out0",
          "language" : "sql",
          "content" : "SELECT /*+ parallel(AMA) parallel(BAL) parallel(ACH) \r \t   parallel(CRH) parallel(SEG) parallel(PRB)\r \t   parallel(CDTL) \r \t   use_hash(AMA BAL ACH CRH SEG PRB CDTL) */\r --       \r   substr('$$MP_BUSDATE',1,6) PERIOD_ID,\r   AMA.ACCID,\r   AMA.ACC_NUM ACCOUNT_NUMBER,\r   DECODE(BAL.MONTHLY_USAGE_INSIDE || BAL.MONTHLY_USAGE_OUTSIDE,'NN', \r   DECODE(BAL.MONTHLY_USAGE_INFLIGHT, 'Y', 'Inflight Only', 'Not Spent'),\r \t  'YN', 'Spent only inside M&S',\r \t  'NY', 'Spent only outside M&S',\r \t  'YY', 'Spent in both',\r \t\t'Not Spent') ACCOUNT_MONTHLY_USAGE,\r   DECODE(BAL.YEARLY_USAGE_INSIDE || BAL.YEARLY_USAGE_OUTSIDE,'NN', \r \t DECODE(BAL.YEARLY_USAGE_INFLIGHT, 'Y', 'Inflight Only', 'Not Spent'),\r \t  'YN', 'Spent only inside M&S',\r \t  'NY', 'Spent only outside M&S',\r \t  'YY', 'Spent in both',\r \t\t'Not Spent') ACCOUNT_YEARLY_USAGE,\r   ACH.STATUS,\r   ACH.BLOCK_CODE,\r   NVL(BAL.BT_FLAG,'N'),\r   CASE WHEN CRH.CURRENT_CARDSAFE_TYPE in ('1','2','3','4') THEN 'Y'\r WHEN NVL(CRH.CURRENT_CARDSAFE_TYPE,'0') in ('0','9') THEN 'N'\r ELSE 'Unknown'\r END CURRENT_CARDSAFE_TYPE,\r   NVL(BAL.CASH_FLAG,'N'),\r   ACH.GBP_AMT_CHARGE_OFF,\r   ACH.ACCOUNT_CREDIT_LIMIT,\r   DECODE(ACH.STATUS,'Z','Charged Off',CASE WHEN ACH.DElQ_210_DAYS > 0 THEN  '210 Days'\r \t  WHEN ACH.DELQ_180_DAYS > 0 THEN  '180 Days'\r \t  WHEN ACH.DELQ_150_DAYS > 0 THEN  '150 Days'\r \t  WHEN ACH.DELQ_120_DAYS > 0 THEN  '120 Days'\r \t  WHEN ACH.DELQ_90_DAYS > 0 THEN  '90 Days'\r \t  WHEN ACH.DELQ_60_DAYS > 0 THEN  '60 Days'\r \t  WHEN ACH.DELQ_30_DAYS > 0 THEN  '30 Days'\r \t  WHEN ACH.PAST_DUE > 0 THEN 'Past Due'\r \t  ELSE 'Current' END) CURRENT_DELINQUENCY,\r --\r -- Begining of Good Bad flag derivation V9_0_1 - revised by SG for Linda Johnson change 20080108\r --\r   CASE \r   WHEN NVL(ACH.GBP_AMT_CHARGE_OFF,0) > 0 THEN\r     '2' -- Bad, Account charged off\r --\r -- Exclusion\r --\r   -- Note: The following uses the current derived Date_Last_Payment,\r   -- not the Date_Last_Payment at the month/week end\r   -- If we have to use the value at month/week end we need to enhance this \r   -- SQL to derive this from Card Transaction (see mapping Credit Card 5)\r --\r   WHEN NVL(BAL.DATE_OF_LAST_PAYMENT, TO_DATE('18991231','YYYYMMDD')) < ADD_MONTHS(AMA.BUSINESS_DATE, -12)\r      AND NVL(ACH.DATE_LAST_PURCHASE, TO_DATE('18991231','YYYYMMDD')) < ADD_MONTHS(AMA.BUSINESS_DATE, -12)\r      AND NVL(ACH.CURR_BALANCE, 0) <= 0 THEN\r     '4' -- Exclusion, inactive more than 12 months\r --\r   WHEN NVL(ACH.DATE_LAST_PURCHASE, TO_DATE('18991231','YYYYMMDD')) = TO_DATE('18991231','YYYYMMDD') THEN\r     '4' -- Exclusion, nilspend\r --\r   WHEN NVL(AMA.DATE_CLOSED, TO_DATE('40001231','YYYYMMDD')) < ADD_MONTHS(AMA.BUSINESS_DATE, -12) THEN\r     '4' -- Exclusion, Account closed more than 12 months\r --\r   WHEN ACH.BLOCK_CODE = 'L' OR ACH.ALT_BLOCK_CODE = 'L' THEN\r     '4' -- Exclusion, Block code lost or stolen\r --\r   WHEN ACH.BLOCK_CODE = 'K' OR ACH.ALT_BLOCK_CODE = 'K' THEN\r     '4' -- Exclusion, Block code Deceased\r --\r -- Bad\r --\r   WHEN (NVL(ACH.DELQ_60_DAYS,0) +  NVL(ACH.DELQ_90_DAYS,0) + NVL(ACH.DELQ_120_DAYS,0) + \r        NVL(ACH.DELQ_150_DAYS,0) + NVL(ACH.DELQ_180_DAYS,0) + NVL(ACH.DELQ_210_DAYS,0)) > 0 THEN\r     '2' -- Bad, 60 days plus\r --\r   WHEN ACH.BLOCK_CODE IN ('F','I','U','B','N','O','G','E') OR ACH.ALT_BLOCK_CODE IN ('F','I','U','B','N','O','G','C','V','W','Z','E') THEN\r     '2' -- Bad, block F,I,U,B,N,O,G,E\r --\r   WHEN NVL(ACH.DELQ_30_DAYS,0) > 0\r      AND (ACH.BLOCK_CODE IN ('A','P','H','Y','J','R')\r        OR ACH.ALT_BLOCK_CODE IN ('A','P','H','Y','J','R')) THEN\r     '2' -- Bad, 30 days, block A,P,H,Y,J,R\r --\r   WHEN NVL(ACH.DELQ_30_DAYS,0) > 0\r      AND NVL(ACH.CURR_BALANCE, 0) > NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) THEN\r     '2' -- Bad, 30 days and over limit\r --\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r      AND (ACH.BLOCK_CODE IN ('Y')\r        OR ACH.ALT_BLOCK_CODE IN ('Y')) THEN\r     '2' -- Bad, past due and block Y\r --\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r      AND ACH.CURR_BALANCE IS NOT NULL\r      AND NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) > 0\r      AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT >= 1.2 \r      THEN\r     '2' -- Bad, past due and balance div limit > 120%\r --\r -- Intermediate\r --\r   WHEN NVL(ACH.DELQ_30_DAYS,0) > 0\r      AND (ACH.BLOCK_CODE IN ('S','X','D','A','V')\r        OR ACH.ALT_BLOCK_CODE IN ('S','X','D','A','V')) THEN\r     '3' -- Intermediate, 30 days and block S,X,D,A,V\r --\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r      AND ((ACH.BLOCK_CODE IN ('A','S','H','M','P','X','R','J')\r      OR ACH.ALT_BLOCK_CODE IN ('A','S','H','M','P','X','R','J'))) \r      THEN\r     '3' -- Intermediate, past due and block A,S,H,M,P,X,R,J\r --\r   WHEN NVL(ACH.CURR_DUE,0) >= 0 \r      AND ACH.PAST_DUE = 0\r      AND ((ACH.BLOCK_CODE IN ('A','S','H','Y','R')\r      OR ACH.ALT_BLOCK_CODE IN ('A','S','H','Y','R'))) \r      THEN\r     '3' -- Intermediate, up to date and block A,S,H,Y,R\r --\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r      AND ACH.CURR_BALANCE IS NOT NULL\r      AND NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) > 0\r      AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT <=  1.2\r      AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT > 1.01 THEN \r     '3' -- Intermediate, past due and balance/limit >101% but <=120%\r --\r   WHEN  NVL(ACH.CURR_DUE,0) >= 0 \r      AND ACH.PAST_DUE = 0\r      AND ACH.CURR_BALANCE IS NOT NULL\r      AND NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) > 0\r      AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT >  1.2 THEN \r     '3' -- Intermediate, up to date and balance/limit >120\r --\r -- Good\r --\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r      AND (ACH.BLOCK_CODE IN ('D','V')\r        OR ACH.ALT_BLOCK_CODE IN ('D','V')) THEN\r     '1' -- Good, past due and block D\r --\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r      AND ACH.CURR_BALANCE IS NOT NULL\r      AND NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) > 0\r      AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT <= 1.01 THEN\r     '1' -- Good, past due and balance/limit <101%\r --\r   WHEN NVL(ACH.CURR_DUE,0) >= 0 \r      AND ACH.PAST_DUE = 0\r      AND ACH.CURR_BALANCE IS NOT NULL\r      AND NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) > 0\r      AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT <= 1.2 THEN\r     '1' -- Good, up to date and balance/limit <=120%\r --\r   ELSE\r     '1'\r   END GOOD_BAD_FLAG,\r --\r   ACH.TOTAL_NUMBER_OF_CARDS,\r   NVL(BAL.INFLIGHT_FLAG,'N'),\r   ACH.LOYALTY_POINTS_BALANCE,\r --\r   NVL(NO_CASH_TRANS_LAST_30_DAYS,0) LAST_30_DAYS_CASH_COUNT,\r   NVL(NO_CASH_TRANS_LAST_90_DAYS,0) LAST_90_DAYS_CASH_COUNT,\r   NVL(NO_CASH_TRANS_LAST_180_DAYS,0) LAST_180_DAYS_CASH_COUNT,\r   NVL(NO_CASH_TRANS_LAST_365_DAYS,0) LAST_365_DAYS_CASH_COUNT,\r   NVL(VAL_CASH_TRANS_LAST_30_DAYS,0) LAST_30_DAYS_CASH_VALUE,\r   NVL(VAL_CASH_TRANS_LAST_90_DAYS,0) LAST_90_DAYS_CASH_VALUE,\r   NVL(VAL_CASH_TRANS_LAST_180_DAYS,0) LAST_180_DAYS_CASH_VALUE,\r   NVL(VAL_CASH_TRANS_LAST_365_DAYS,0) LAST_365_DAYS_CASH_VALUE,\r --\r   NVL(NO_RETINF_TRANS_LAST_30_DAYS,0) LAST_30_DAYS_RET_INF_COUNT,\r   NVL(NO_RETINF_TRANS_LAST_90_DAYS,0) LAST_90_DAYS_RET_INF_COUNT,\r   NVL(NO_RETINF_TRANS_LAST_180_DAYS,0) LAST_180_DAYS_RET_INF_COUNT,\r   NVL(NO_RETINF_TRANS_LAST_365_DAYS,0) LAST_365_DAYS_RET_INF_COUNT,\r   NVL(VAL_RETINF_TRANS_LAST_30_DAYS,0) LAST_30_DAYS_RET_INF_VALUE,\r   NVL(VAL_RETINF_TRANS_LAST_90_DAYS,0) LAST_90_DAYS_RET_INF_VALUE,\r   NVL(VAL_RETINF_TRANS_LAST_180_DAYS,0) LAST_180_DAYS_RET_INF_VALUE,\r   NVL(VAL_RETINF_TRANS_LAST_365_DAYS,0) LAST_365_DAYS_RET_INF_VALUE,\r --\r   NVL(BAL.RETAIL_FLAG,'N'),\r --\r   NVL(NO_BT_TRANS_LAST_30_DAYS,0) LAST_30_DAYS_BT_TFR_COUNT,\r   NVL(NO_BT_TRANS_LAST_90_DAYS,0) LAST_90_DAYS_BAL_TFR_COUNT,\r   NVL(NO_BT_TRANS_LAST_180_DAYS,0) LAST_180_DAYS_BAL_TFR_COUNT,\r   NVL(NO_BT_TRANS_LAST_365_DAYS,0) LAST_365_DAYS_BAL_TFR_COUNT,\r   NVL(VAL_BT_TRANS_LAST_30_DAYS,0) LAST_30_DAYS_BAL_TFR_VALUE,\r   NVL(VAL_BT_TRANS_LAST_90_DAYS,0) LAST_90_DAYS_BAL_TFR_VALUE,\r   NVL(VAL_BT_TRANS_LAST_180_DAYS,0) LAST_180_DAYS_BAL_TFR_VALUE,\r   NVL(VAL_BT_TRANS_LAST_365_DAYS,0) LAST_365_DAYS_BAL_TFR_VALUE,\r --\r   ACH.CURR_BALANCE,\r   ACH.DATE_CREDIT_LIMIT,\r   ACH.PAYMENT_METHOD,\r   CRH.DUE_LAST_STMT,\r   ACH.INSURANCE_STATUS, \r   ACH.PREVIOUS_CREDIT_LIMIT,\r   NVL(BAL.SCHEME_ACTIVE,'N'),\r   ACH.CHARGE_OFF_DATE,\r   NVL(CDTL.ACCOUNT_ACTIVATED,'N'),\r   ACH.INS_IND,\r   SEG.SEGMENT,\r   BAL.DATE_OF_LAST_CRDCARD_PURCH,\r   ACH.CHARGE_OFF_REASON_1,\r   ACH.CHARGE_OFF_REASON_2,\r   PRB.SCORE_1,\r   CRP.TOT_BEGINNING_BALANCE,\r --  \r   CASE WHEN AMA.CC_MIGRATION_DATE IS NOT NULL \r     THEN 'Migrated'\r --  \r   WHEN AMA.CC_MIGRATION_DATE IS NULL\r     AND AMA.SC_STATUS IN ('0','1','2','3','4','5')\r     THEN 'Existing Storecard Customer'\r --\r   WHEN AMA.AUTHORISED_USER = 'Y'\r     THEN 'Existing Storecard Customer'\r --\r   WHEN AMA.CC_MIGRATION_DATE IS NULL\r     AND AMA.SC_STATUS IN ('4','5','8','9')\r     AND NVL(AMA.SC_DATE_CLOSED,TO_DATE('18990131','YYYYMMDD')) > TO_DATE('20021028','YYYYMMDD')\r     THEN 'Existing Storecard Customer'\r --\r   ELSE 'Real New' END NEW_SELF_MIG_IND,\r --\r   CRH.NUM_CARDS,\r --\r   ACH.CREDIT_LIMIT_CASH,\r   ACH.past_due+ACH.delq_30_days+ACH.delq_60_days+\r   ACH.delq_90_days+ACH.delq_120_days+ACH.delq_150_days+\r   ACH.delq_180_days+ACH.delq_210_days ARREARS_VALUE,\r   CRP.CURRENT_BALANCE_BT,\r   CRP.CURRENT_BALANCE_CASH,\r   CRP.CURRENT_BALANCE_RETAIL,\r   ACH.ALT_BLOCK_CODE BLOCK_CODE_2,\r   CASE \r   WHEN DD_PAYMENT_FLAG IN ('N','0') OR LENGTH(LTRIM(RTRIM(DD_PAYMENT_FLAG))) = 0 OR DD_PAYMENT_FLAG IS NULL\r   THEN 'Not a DD payment'\r   WHEN DD_PAYMENT_FLAG = 'M' \r   THEN 'Min balance DD'\r   WHEN DD_PAYMENT_FLAG = 'B'\r   THEN 'Full payer DD'\r   WHEN DD_PAYMENT_FLAG = 'F'\r   THEN 'Customer initiated fixed DD'\r   WHEN DD_PAYMENT_FLAG = 'X'\r   THEN 'Collection initiated fixed DD'\r   ELSE 'Unknown'\r   END as DD_PAYMENT_FLAG,\r   --\r    CRH.EMPLOYEE_CODE,\r    CRH.PAYROLL_NO,\r    ACH.STMT_FLAG,\r    ACH.USER_CODE_9,\r   --\r    ACH.ACHOLDER_NOMINATED_AMOUNT\r FROM\r   (SELECT \r     ACCID,\r     MAX(CASE WHEN (ACTIVATION_REQ = 'N' AND CURR_PREV_IND = '1') \r \t    THEN 'Y'\r \t WHEN (ACTIVATION_REQ = 'Y' AND ACTIVATION_RQD_PREV = 'N' AND CURR_PREV_IND = '1' AND\r \t       PRIOR_CARD_EXPIRY > TO_DATE('$$MP_BUSDATE','YYYYMMDD'))\r \t    THEN 'Y'\r \t ELSE 'N'\r      END) ACCOUNT_ACTIVATED\r      FROM minervarep.CARD_DETAIL CDT\r      WHERE TO_DATE('$$MP_BUSDATE','YYYYMMDD') between CDT.EFROM AND NVL(CDT.ETO,TO_DATE('01014000','DDMMYYYY'))\r      GROUP BY ACCID) CDTL,\r   (\r   SELECT ACCID,\r \t SCORE_1\r   FROM\r   (SELECT PB1.ACCID,\r \t  PB1.SCORE_1,\r \t  RANK() OVER(PARTITION BY PB1.ACCID ORDER BY PB1.RUN_DATE DESC) RNK\r      FROM minervarep.TRIAD_SCORE PB1\r      WHERE MONTHID = TO_CHAR(SUBSTR('$$MP_BUSDATE',1,6)))\r      WHERE RNK = 1     \r   ) PRB,\r --\r   (\r   SELECT /*+ parallel(PLN) */\r       PLN.ACCID,\r       SUM(DECODE(PLN.PLAN_TYPE, 'C', PLN.CURRENT_BALANCE, 0)) CURRENT_BALANCE_CASH,\r       SUM(DECODE(PLN.PLAN_TYPE, 'R', PLN.CURRENT_BALANCE, 0)) CURRENT_BALANCE_RETAIL,\r       SUM(DECODE(PLN.PLAN_TYPE, 'B', PLN.CURRENT_BALANCE,\r                                 'T', PLN.CURRENT_BALANCE, 0)) CURRENT_BALANCE_BT,\r       SUM(PLN.BEGINNING_BALANCE) TOT_BEGINNING_BALANCE\r     FROM minervarep.CREDIT_PLAN_BALANCE partition(hot) PLN\r     WHERE TO_DATE('$$MP_BUSDATE','YYYYMMDD') BETWEEN PLN.EFROM AND NVL(PLN.ETO,TO_DATE('40001231','YYYYMMDD'))\r   GROUP BY PLN.ACCID\r   ) CRP,\r --\r   (\r   SELECT /*+ parallel(SG1) */\r \t SG1.ACCID,\r \t SG1.SEGMENT\r     FROM minervarep.MRT_MONTHLY_CC_SEGMENT SG1\r   ) SEG,\r --  \r   (SELECT ACCID,\r \t  SCHEME_ACTIVE,\r \t  MONTHLY_USAGE_INSIDE,\r \t  MONTHLY_USAGE_OUTSIDE,\r \t  MONTHLY_USAGE_INFLIGHT,\r \t  YEARLY_USAGE_INSIDE,\r \t  YEARLY_USAGE_OUTSIDE,\r \t  YEARLY_USAGE_INFLIGHT,\r \t  DATE_OF_LAST_CRDCARD_PURCH,\r \t  BT_FLAG,\r \t  CASH_FLAG,\r \t  INFLIGHT_FLAG,\r \t  RETAIL_FLAG,\r           DATE_OF_LAST_PAYMENT,\r \t  NO_BT_TRANS_LAST_30_DAYS,\r \t  NO_BT_TRANS_LAST_90_DAYS,\r \t  NO_BT_TRANS_LAST_180_DAYS,\r \t  NO_BT_TRANS_LAST_365_DAYS,          \r \t  VAL_BT_TRANS_LAST_30_DAYS,\r \t  VAL_BT_TRANS_LAST_90_DAYS,\r \t  VAL_BT_TRANS_LAST_180_DAYS,\r \t  VAL_BT_TRANS_LAST_365_DAYS,\r \t  NO_CASH_TRANS_LAST_30_DAYS,\r \t  NO_CASH_TRANS_LAST_90_DAYS,\r \t  NO_CASH_TRANS_LAST_180_DAYS,\r \t  NO_CASH_TRANS_LAST_365_DAYS,          \r \t  VAL_CASH_TRANS_LAST_30_DAYS,\r \t  VAL_CASH_TRANS_LAST_90_DAYS,\r \t  VAL_CASH_TRANS_LAST_180_DAYS,\r \t  VAL_CASH_TRANS_LAST_365_DAYS,\r \t  NO_RETINF_TRANS_LAST_30_DAYS,\r \t  NO_RETINF_TRANS_LAST_90_DAYS,\r \t  NO_RETINF_TRANS_LAST_180_DAYS,\r \t  NO_RETINF_TRANS_LAST_365_DAYS,          \r \t  VAL_RETINF_TRANS_LAST_30_DAYS,\r \t  VAL_RETINF_TRANS_LAST_90_DAYS,\r \t  VAL_RETINF_TRANS_LAST_180_DAYS,\r \t  VAL_RETINF_TRANS_LAST_365_DAYS\r     FROM minervarep.mrt_credit_card_5         \r   ) BAL,\r --\r -- Get data ready for derivation of the ACCOUNT_ORIGIN Attribute\r --\r (SELECT A.CLIENTID,\r         A.HOUSEID,\r         A.ACC_NUM,\r         A.STATUS,\r         A.DATE_CLOSED,\r         A.ACCID,\r         A.MIGRATION_DATE CC_MIGRATION_DATE,\r         A.BUSINESS_DATE,\r         B.AUTHORISED_USER,\r         B.STATUS SC_STATUS,\r         B.DATE_CLOSED SC_DATE_CLOSED\r  FROM\r (SELECT AMA1.CLIENTID, \r         AMA1.HOUSEID,\r         AMA1.ACC_NUM,\r         AMA1.ACCID,\r         AMA1.MIGRATION_DATE,\r         AMA1.STATUS,\r         AMA1.DATE_CLOSED,\r         AMA1.BUSINESS_DATE\r  FROM \r  minervarep.ALL_MONTHLY_ACCOUNTS AMA1\r  WHERE  AMA1.ACC_TYPE IN ('410','420','510','520')\r  ) A,\r (SELECT HLDB.CLID CLIENTID, \r         MAX(AMA2.ACCID) ACCID, \r         MAX(AMA2.MIGRATION_DATE) MIGRATION_DATE, \r         MIN(AMA2.STATUS) STATUS,\r         MAX(AMA2.DATE_CLOSED) DATE_CLOSED,\r         MAX(DECODE(AUT.ACCID,NULL,'N','Y')) AUTHORISED_USER\r  FROM minervarep.ALL_MONTHLY_ACCOUNTS AMA2,\r  minervarep.HOLDS HLDB,\r  minervarep.AUTHORISED_USER AUT\r  WHERE AMA2.ACC_TYPE IN ('001','010','011','012')\r  AND AMA2.ACCID = HLDB.ACCID\r  AND AMA2.ACCID = AUT.ACCID (+)\r  AND HLDB.MERGE_CLID IS NULL\r  AND TO_DATE('$$MP_BUSDATE','YYYYMMDD') BETWEEN HLDB.EFROM AND NVL(HLDB.ETO,TO_DATE('40001231','YYYYMMDD'))\r  GROUP BY HLDB.CLID) B\r WHERE A.CLIENTID = B.CLIENTID(+)) AMA,\r --  \r   minervarep.ACCOUNT ACH, \r   minervarep.CARD CRH\r --              \r WHERE AMA.ACCID    = ACH.ACCID\r   AND AMA.ACCID    = PRB.ACCID(+)\r   AND AMA.ACCID    = CRH.ACCID\r   AND AMA.ACCID    = BAL.ACCID(+)\r   AND AMA.ACCID    = SEG.ACCID(+)\r   AND AMA.ACCID    = CDTL.ACCID(+)\r   AND AMA.ACCID    = CRP.ACCID(+)"
        } ]
      },
