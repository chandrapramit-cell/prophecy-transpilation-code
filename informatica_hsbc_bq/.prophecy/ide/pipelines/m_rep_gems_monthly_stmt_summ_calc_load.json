    "SQ_CREDIT_CARD_STATEMENT_SUMMARY" : {
      "id" : "SQ_CREDIT_CARD_STATEMENT_SUMMARY",
      "component" : "SQLStatement",
      "metadata" : {
        "label" : "SQ_CREDIT_CARD_STATEMENT_SUMMARY",
