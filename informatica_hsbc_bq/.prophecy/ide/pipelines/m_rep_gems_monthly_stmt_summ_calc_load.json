        }, {
          "expression" : {
            "expression" : "(CASE WHEN ((CASE WHEN (CURR_PERIOD = CAST (SUBSTRING(BUSINESS_DATE , 0 , 6) AS FLOAT64)) THEN 'Y' ELSE 'N' END) = 'Y') THEN CURR_VAL_CREDITS ELSE 0 END)"
