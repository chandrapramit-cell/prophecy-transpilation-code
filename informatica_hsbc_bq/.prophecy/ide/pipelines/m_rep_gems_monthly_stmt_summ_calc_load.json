          "_row_id" : "usZIHQXRttQgMcP39Hh0d"
        }, {
          "expression" : {
            "expression" : "(CASE WHEN ((CASE WHEN (CURR_PERIOD = CAST (SUBSTRING(BUSINESS_DATE , 0 , 6) AS FLOAT64)) THEN 'Y' ELSE 'N' END) = 'Y') THEN CURR_STATEMENT_BALANCE_TOTAL ELSE 0 END)"
