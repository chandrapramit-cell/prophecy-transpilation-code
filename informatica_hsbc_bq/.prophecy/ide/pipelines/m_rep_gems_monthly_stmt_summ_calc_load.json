        }, {
          "expression" : {
            "expression" : "(\n  CASE\n    WHEN (\n      (\n        CASE\n          WHEN (\n            PREV_PERIOD = CAST(SUBSTRING(\n              (PARSE_TIMESTAMP('%Y%m%d', (DATE_ADD(CAST((PARSE_TIMESTAMP('%Y%m%d', BUSINESS_DATE)) AS DATE), INTERVAL -1 MONTH)))), \n              0, \n              6) AS FLOAT64)\n          )\n            THEN 'Y'\n          ELSE 'N'\n        END\n      ) = 'Y'\n    )\n      THEN PREV_TOTAL_INT\n    ELSE 0\n  END\n)"
