          "warehouseQuery" : {
            "query" : "SELECT /*+ parallel(AMA) parallel(A) parallel(B) use_hash(AMA A B) */\r AMA.ACCID AS ACCID,\r A.PERIOD AS CURR_PERIOD,\r B.PERIOD AS PREV_PERIOD,\r NVL(A.STATEMENT_BALANCE_TOTAL,0) AS CURR_STATEMENT_BALANCE_TOTAL,\r NVL(A.TOTAL_INT_THIS_STMT,0) AS CURR_TOTAL_INT_THIS_STATEMENT,\r NVL(A.VAL_CREDITS,0) AS CURR_VAL_CREDITS,\r NVL(B.STATEMENT_BALANCE_TOTAL,0) AS PREV_STATEMENT_BALANCE_TOTAL,\r NVL(B.TOTAL_INT_THIS_STMT,0) AS         PREV_TOTAL_INT_THIS_STATEMENT,\r NVL(B.VAL_CREDITS,0) AS PREV_VAL_CREDITS,\r AMA.CYCLE_DAY AS CYCLE_DAY,\r A.BUSINESS_DATE\r FROM\r ALL_MONTHLY_ACCOUNTS AMA,\r (SELECT /*+ parallel(VEWA,4) */\r * FROM (\r SELECT /*+ parallel(CCSS) */\r             ACCID,\r             PERIOD,\r             STATEMENT_BALANCE_TOTAL,\r             TOTAL_INT_THIS_STMT,\r             VAL_CREDITS,\r             '$$MP_BUSDATE' BUSINESS_DATE,\r             RANK() over (partition by accid order by period desc, statement_date desc)  RANK_NUM\r          FROM CREDIT_CARD_STATEMENT_SUMMARY CCSS\r          WHERE PERIOD <= SUBSTR('$$MP_BUSDATE',1,6)) VEWA\r       WHERE RANK_NUM = 1) A,\r (SELECT /*+ parallel(VEWB) */\r * FROM (\r SELECT /*+ parallel(CCSSB) */\r             ACCID,\r             PERIOD,\r             STATEMENT_BALANCE_TOTAL,\r             TOTAL_INT_THIS_STMT,\r             VAL_CREDITS,\r             RANK() over (partition by accid order by  period desc, statement_date desc)  RANK_NUM\r          FROM CREDIT_CARD_STATEMENT_SUMMARY CCSSB\r          WHERE PERIOD <= SUBSTR('$$MP_BUSDATE',1,6)) VEWB\r       WHERE RANK_NUM = 2) B\r WHERE AMA.ACCID = B.ACCID(+)\r AND   AMA.ACCID = A.ACCID\r AND  AMA.ACC_TYPE in ('410','420','510','520')"
          }
