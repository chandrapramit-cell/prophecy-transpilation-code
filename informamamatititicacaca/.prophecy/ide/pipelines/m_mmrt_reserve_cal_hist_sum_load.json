            "name" : "MinervaRepository"
          },
          "warehouseQuery" : {
            "query" : "SELECT /*+ parallel(AMA) parallel(ACH) parallel(CRH) parallel(BHS)\r            use_hash(AMA ACH CRH BHS) */\r --\r AMA.ACCID,\r SUBSTR(TO_CHAR(AMA.BUSINESS_DATE,'YYYYMMDD'),1,6) PERIODID,\r AMA.ACC_NUM,\r ACH.STATUS,\r NVL(ACH.PAST_DUE, 0) + NVL(ACH.DELQ_30_DAYS, 0) + NVL(ACH.DELQ_60_DAYS, 0) +\r \tNVL(ACH.DELQ_90_DAYS, 0) + NVL(ACH.DELQ_120_DAYS, 0) + NVL(ACH.DELQ_150_DAYS, 0) +\r \tNVL(ACH.DELQ_180_DAYS, 0) + NVL(ACH.DELQ_210_DAYS, 0) ARREARS_VALUE,\r ACH.BLOCK_CODE,\r ACH.GBP_AMT_CHARGE_OFF,\r ACH.ACCOUNT_CREDIT_LIMIT,\r ACH.CURR_DUE,\r ACH.CURR_BALANCE,\r ACH.CYCLE_DAY,\r ACH.DELQ_120_DAYS,\r ACH.DELQ_150_DAYS,\r ACH.DELQ_180_DAYS,\r ACH.DELQ_210_DAYS,\r ACH.DELQ_30_DAYS,\r ACH.DELQ_60_DAYS,\r ACH.DELQ_90_DAYS,\r --\r CASE\tWHEN NVL(ACH.GBP_AMT_CHARGE_OFF,0) > 0 THEN\r \t    '2'\r \tWHEN NVL(ACH.DATE_LAST_PYMT, TO_DATE('18990101','YYYYMMDD')) < ADD_MONTHS(AMA.BUSINESS_DATE, -24)\r \t     AND NVL(ACH.DATE_LAST_PURCHASE, TO_DATE('18990101','YYYYMMDD')) < ADD_MONTHS(AMA.BUSINESS_DATE, -24)\r \t     AND NVL(ACH.CURR_BALANCE, 0) <= 0 THEN\r \t    '4'\r \tWHEN ACH.DATE_LAST_PYMT IS NULL\r \t     AND ACH.DATE_LAST_PURCHASE IS NULL\r \t     AND ACH.CURR_BALANCE = 0 THEN\r \t    '4'\r \tWHEN NVL(AMA.DATE_CLOSED, TO_DATE('40001231','YYYYMMDD')) < ADD_MONTHS(AMA.BUSINESS_DATE, -12) THEN\r \t    '4'\r \tWHEN (NVL(ACH.DELQ_30_DAYS,0) + NVL(ACH.DELQ_60_DAYS,0) +\r \t      NVL(ACH.DELQ_90_DAYS,0) + NVL(ACH.DELQ_120_DAYS,0) + NVL(ACH.DELQ_150_DAYS,0) +\r \t      NVL(ACH.DELQ_180_DAYS,0) + NVL(ACH.DELQ_210_DAYS,0)) > 0 THEN\r \t    '2'\r \tWHEN ACH.BLOCK_CODE IN ('F','L','R','U','W','Y') THEN\r \t    '2'\r \tWHEN NVL(ACH.PAST_DUE,0) > 0\r \t     AND ACH.BLOCK_CODE IN ('A','E','G','T','X','K') THEN\r \t    '2'\r \tWHEN NVL(ACH.PAST_DUE,0) > 0\r \t     AND ACH.CURR_BALANCE IS NOT NULL\r \t     AND NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) > 0\r \t     AND NVL(ACH.CURR_BALANCE, 0) > NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) THEN\r \t    '2'\r \tWHEN (NVL(ACH.CURR_DUE,0) > 0 OR NVL(ACH.CURR_DUE,0) = 0)\r \t     AND NVL(ACH.PAST_DUE,0) = 0\r \t     AND ACH.CURR_BALANCE IS NOT NULL\r \t     AND NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) > 0\r \t     AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT >= 1.05 THEN\r \t    '2'\r \tWHEN NVL(ACH.PAST_DUE,0) > 0 THEN\r \t    '3'\r \tWHEN NVL(ACH.CURR_DUE,0) >= 0 \r \t     AND ACH.BLOCK_CODE IN ('A','D','G','I','Q','T','E','X','K') THEN\r \t    '3'\r \tWHEN NVL(ACH.CURR_DUE,0) >= 0\r \t     AND ACH.CURR_BALANCE IS NOT NULL \r \t     AND NVL(ACH.ACCOUNT_CREDIT_LIMIT,0) > 0\r \t     AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT < 1.05\r \t     AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT >= 1.02 THEN\r \t    '3'\r \tELSE\r \t    '1'\r END GOOD_BAD_FLAG,\r --\r ACH.LOYALTY_IND,\r CRH.OVERLIMIT_FLAG,\r ACH.PAST_DUE,\r ACH.PAYMENT_METHOD,\r CRH.SHADOW_LIMIT,\r BHS.SCORE,\r ACH.USER_CODE_1,\r ACH.USER_CODE_2\r --\r FROM\tALL_MONTHLY_ACCOUNTS AMA,\r \tACCOUNT ACH,\r \tCARD CRH,\r   \tBEHAVIOUR_SCORE BHS\r --\r WHERE AMA.ACCID = ACH.ACCID\r   AND AMA.ACCID = CRH.ACCID\r   AND AMA.ACCID = BHS.ACCID (+)\r   AND AMA.ACC_TYPE = '300'\r   AND AMA.BUSINESS_DATE BETWEEN BHS.EFROM(+) AND NVL(BHS.ETO(+), TO_DATE('40001231','YYYYMMDD'))\r   AND AMA.CLIENTID IS NOT NULL"
          }
        },
