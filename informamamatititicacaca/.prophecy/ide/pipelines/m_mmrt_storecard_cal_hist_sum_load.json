                  }
                } ]
              }
            },
            "name" : "MinervaRepository"
          },
          "warehouseQuery" : {
            "query" : "SELECT /*+ parallel(AMA) parallel(ACH) parallel(MRT) \r            parallel(BHS) parallel(CRD) full(CRD)\r            use_hash(AMA ACH BHS MRT CRD) */\r --\r AMA.ACCID,\r AMA.PERIODID,\r AMA.ACC_NUM,\r ACH.STATUS,\r ACH.BLOCK_CODE,\r ACH.GBP_AMT_CHARGE_OFF,\r ACH.ACCOUNT_CREDIT_LIMIT,\r ACH.CURR_BALANCE,\r ACH.DELQ_120_DAYS,\r ACH.DELQ_150_DAYS,\r ACH.DELQ_180_DAYS,\r ACH.DELQ_210_DAYS,\r ACH.DELQ_30_DAYS,\r ACH.DELQ_60_DAYS,\r ACH.DELQ_90_DAYS,\r --\r CASE WHEN NVL(ACH.GBP_AMT_CHARGE_OFF,0) > 0 THEN\r     '2'\r   WHEN NVL(ACH.DATE_LAST_PYMT, TO_DATE('18990101','YYYYMMDD')) < ADD_MONTHS(AMA.END_DATE, -24)\r        AND NVL(ACH.DATE_LAST_PURCHASE, TO_DATE('18990101','YYYYMMDD')) < ADD_MONTHS(AMA.END_DATE, -24)\r        AND NVL(ACH.CURR_BALANCE, 0) <= 0 THEN\r     '4'\r   WHEN ACH.DATE_LAST_PYMT IS NULL\r        AND ACH.DATE_LAST_PURCHASE IS NULL\r        AND NVL(ACH.CURR_BALANCE,0) = 0 THEN\r     '4'\r   WHEN NVL(AMA.DATE_CLOSED, TO_DATE('40001231','YYYYMMDD')) < ADD_MONTHS(AMA.END_DATE, -12) THEN\r     '4'\r   WHEN ACH.BLOCK_CODE IN ('M','N','S')\r   THEN\r     '4'\r   WHEN (NVL(ACH.DELQ_60_DAYS,0) + NVL(ACH.DELQ_90_DAYS,0) + NVL(ACH.DELQ_120_DAYS,0) +\r        NVL(ACH.DELQ_150_DAYS,0) + NVL(ACH.DELQ_180_DAYS,0) + NVL(ACH.DELQ_210_DAYS,0)) > 0 THEN\r     '2'\r   WHEN ACH.BLOCK_CODE IN ('F','L','W')\r   THEN\r     '2'\r   WHEN NVL(ACH.DELQ_30_DAYS,0) > 0\r        AND ACH.BLOCK_CODE IN ('A','E','G','I','R','T','U','X','K','Y')\r   THEN\r     '2'\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r        AND ACH.BLOCK_CODE IN ('E','G','R','T','U','K','Y')\r   THEN\r     '2'\r   WHEN NVL(ACH.DELQ_30_DAYS,0) > 0\r        AND ACH.CURR_BALANCE IS NOT NULL \r        AND NVL(ACH.ACCOUNT_CREDIT_LIMIT,0) > 0\r        AND NVL(ACH.CURR_BALANCE, 0) > NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) THEN\r     '2'\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r        AND NVL(ACH.DELQ_30_DAYS,0) = 0\r        AND ACH.CURR_BALANCE IS NOT NULL\r        AND NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) > 0\r        AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT >= 1.25 THEN\r     '2'\r   WHEN NVL(ACH.PAST_DUE,0) = 0\r        AND NVL(ACH.DELQ_30_DAYS,0) = 0\r        AND ACH.CURR_BALANCE IS NOT NULL\r        AND NVL(ACH.ACCOUNT_CREDIT_LIMIT, 0) > 0\r        AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT >= 1.4 THEN\r     '2'\r   WHEN NVL(ACH.DELQ_30_DAYS,0) > 0 THEN\r     '3'\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r        AND ACH.BLOCK_CODE IN ('A','B','D','I','J','O','Q','X')\r   THEN\r     '3'\r   WHEN NVL(ACH.CURR_DUE,0) >= 0 \r        AND NVL(ACH.PAST_DUE,0) = 0\r        AND ACH.BLOCK_CODE IN ('D','E','I','G','Q','R','T','X','Y','U','K')\r   THEN\r     '3'\r   WHEN NVL(ACH.PAST_DUE,0) > 0\r        AND ACH.CURR_BALANCE IS NOT NULL\r        AND NVL(ACH.ACCOUNT_CREDIT_LIMIT,0) > 0\r        AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT <  1.25\r        AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT >= 1.02 THEN\r     '3'\r   WHEN ACH.CURR_DUE >= 0 \r        AND NVL(ACH.PAST_DUE,0) = 0\r        AND ACH.CURR_BALANCE IS NOT NULL\r        AND NVL(ACH.ACCOUNT_CREDIT_LIMIT,0) > 0\r        AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT <  1.4\r        AND ACH.CURR_BALANCE / ACH.ACCOUNT_CREDIT_LIMIT >= 1.25 THEN\r     '3'\r   ELSE\r     '1'\r END GOOD_BAD_FLAG,\r --\r ACH.LOYALTY_POINTS_BALANCE,\r ACH.PAYMENT_METHOD,\r ACH.DATE_LAST_PURCHASE,\r ACH.PAST_DUE,\r AMA.PYMT_FLAG,\r NVL(ACH.PREVIOUS_CREDIT_LIMIT,ACH.ACCOUNT_CREDIT_LIMIT) PREVIOUS_CREDIT_LIMIT,\r ACH.CHARGE_OFF_DATE,\r CRD.CURRENT_CARDSAFE_TYPE,\r ACH.INS_IND,\r --\r DECODE(AMA.STORECARD_SCHEME_ACTIVE,'Y','ACTIVE','N','INACTIVE','ERROR') ACTIVITY_STATUS,\r --  \r ACH.DATE_CREDIT_LIMIT,\r MRT.SEGMENT,\r BHS.SCORE,\r CRD.NUM_CARDS,\r ACH.past_due+ACH.delq_30_days+ACH.delq_60_days+\r ACH.delq_90_days+ACH.delq_120_days+ACH.delq_150_days+\r ACH.delq_180_days+ACH.delq_210_days ARREARS_VALUE,\r ACH.ACCOUNT_SHADOW_LIMIT,\r CRD.OVERLIMIT_FLAG,\r ACH.USER_CODE_1,\r ACH.USER_CODE_2\r FROM\r   (\r   SELECT /*+ parallel(AMA) parallel(CAL) use_hash(AMA CAL) */\r     AMA.ACCID, \r     AMA.CLIENTID, \r     AMA.HOUSEID, \r     AMA.ACC_NUM, \r     AMA.DATE_CLOSED,\r     TO_NUMBER(SUBSTR('$$MP_BUSDATE',1,6)) PERIODID,\r     TO_DATE('$$MP_BUSDATE','YYYYMMDD') END_DATE,\r     CT.LAST_EFFECTIVE_DATE AS EFF_DATE,\r     NVL(CT.STORECARD_SCHEME_ACTIVE,'N') STORECARD_SCHEME_ACTIVE,\r     AMA.PYMT_FLAG\r     FROM ALL_MONTHLY_ACCOUNTS AMA,\r          MRT_SCARD_TRANS_DERIVATIONS CT\r     WHERE AMA.ACCID = CT.ACCID (+)\r     AND   AMA.ACC_TYPE IN ('001','010','011','012')\r     AND   AMA.CLIENTID IS NOT NULL\r   ) AMA,\r   ACCOUNT ACH,\r   CARD CRD,\r   BEHAVIOUR_SCORE BHS,\r   MRT_MONTHLY_SC_SEGMENT MRT\r --\r WHERE AMA.ACCID = ACH.ACCID\r   AND ACH.ACC_TYPE IN ('001','010','011','012')\r   AND AMA.ACCID = MRT.ACCID\r   AND AMA.ACCID = BHS.ACCID (+)\r   AND AMA.ACCID = CRD.ACCID\r   AND AMA.END_DATE BETWEEN BHS.EFROM (+) AND NVL(BHS.ETO (+), TO_DATE('40001231', 'YYYYMMDD'))"
          }
        },
