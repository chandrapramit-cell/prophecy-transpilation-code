          "warehouseQuery" : {
            "query" : "SELECT /*+ parallel(TRN) parallel(AMA) use_hash(TRN AMA) */\r --           \r   TRN.ACCID,\r   AMA.ACC_TYPE,\r --\r -- LAST Transaction Effective Date\r --\r NULL as LAST_SCHEME_ACTIVE_EFF_DATE,\r --\r MAX(CASE WHEN TRANSACTION_CODE = '40'\r       AND EFFECTIVE_DATE BETWEEN \r       TO_DATE(\r       ADD_MONTHS(TO_DATE('$$MP_BUSDATE','YYYYMMDD'),-3)+1) AND TO_DATE('$$MP_BUSDATE','YYYYMMDD')\r       THEN 'Y'\r       ELSE 'N'\r     END) STORECARD_SCHEME_ACTIVE,\r --\r   MAX(CASE WHEN EFFECTIVE_DATE <= TO_DATE ('$$MP_BUSDATE', 'YYYYMMDD')\r            THEN EFFECTIVE_DATE\r            ELSE NULL\r            END) LAST_EFFECTIVE_DATE\r --\r FROM \r (SELECT /*+ parallel(TR1) */ \r         ACCID, \r         EFFECTIVE_DATE, \r         POSTING_DATE, \r        TRANSACTION_CODE\r         from STORECARD_TRANSACTION TR1\r         WHERE TRANSACTION_CODE = '40') TRN,\r   ALL_MONTHLY_ACCOUNTS AMA\r --\r WHERE TRN.ACCID = AMA.ACCID\r --\r GROUP BY TRN.ACCID,\r          AMA.ACC_TYPE"
