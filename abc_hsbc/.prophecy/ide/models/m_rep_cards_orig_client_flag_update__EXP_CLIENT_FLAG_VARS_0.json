          "language" : "sql",
          "content" : "select /*+ parallel(wrk) parallel(ca) parallel(cf) \r            use_hash(wrk ca cf) */\r \t   distinct\r        ca.clid,\r        ca.merge_clid,\r \t   wrk.application_status,\r        wrk.last_action_date\r from  (select\r            customer_number,application_status,max(last_action_date) as last_action_date\r            from work_cards_orig_staging wrk\r           where customer_number is not null\r            group by \r            customer_number,application_status) wrk,\r \t  client_alias ca,\r \t  client_flag cf\r where \r      wrk.customer_number = ca.source_client_ref (+)\r and   ca.clid = cf.clid (+)\r and   ca.source_system_code  = 'U'\r and   ca.source_type  = 0\r and   ca.eto is null\r and   ca.class = '585'\r and   cf.class  (+)  = '206'\r and   cf.subclass (+) = '296'\r and   cf.source_type (+) = 0\r and   cf.eto (+) is null\r and   cf.clid is null"
