      "properties" : {
        "fileTabs" : [ {
          "path" : "out0",
          "id" : "out0",
          "language" : "sql",
          "content" : "select /*+ parallel(cus) parallel(ca) parallel(cp) use_hash(cus ca cp) */\r        distinct \r        ca.clid as client_alias_clid,\r        cp.clid as client_preference_clid,\r \t   case when MARKETING_PREFERENCES_PREFERRED_CHANNELS='CALL'\r \t        then 'Y' else 'N'\r \t   end as marketing_opt_in_tel,\r \t   case when MARKETING_PREFERENCES_PREFERRED_CHANNELS='EMAIL'\r \t        then 'Y' else 'N'\r \t   end as marketing_opt_in_email,\r \t   case when MARKETING_PREFERENCES_PREFERRED_CHANNELS='SMS'\r \t        then 'Y' else 'N'\r \t   end as marketing_opt_in_text,\r \t   case when MARKETING_PREFERENCES_PREFERRED_CHANNELS='POST'\r \t        then 'Y' else 'N'\r \t   end as marketing_opt_in_post,\r        cp.mail_preference,\r        cp.mail_preference_date,\r        cp.phone_preference,\r        cp.phone_preference_date,\r        cp.email_preference,\r        cp.email_preference_date,\r        cp.sms_preference,\r        cp.sms_preference_date,\r        row_number() over (partition by cus.customer_number order by cus.last_action_date desc) row_number\r from   work_cards_orig_staging cus,\r        client_alias ca,\r        client_preference cp\r where  cus.customer_number = ca.source_client_ref (+)\r and    cus.customer_number is not null\r and    ca.source_type (+) = 0\r and    ca.source_system_code (+) = 'U'\r and    ca.eto (+) is null\r and    ca.clid = cp.clid (+)\r and    ca.class (+) = '585'\r and    cp.source_system_code (+) = 'U'"
        } ]
      },
