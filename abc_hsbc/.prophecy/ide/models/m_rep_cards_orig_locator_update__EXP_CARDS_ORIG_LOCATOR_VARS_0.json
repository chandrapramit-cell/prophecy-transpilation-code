          "content" : "select *\r from\r (\r select /*+ parallel(cus) parallel(ca) parallel(l) use_hash(cus ca l) */\r         ca.clid AS clid,\r         ca.merge_clid AS merge_clid,\r         402 as class,\r         417 as subclass,\r         ltrim(rtrim(cus.email)) as value,\r         l.clid as lkp_clid,\r         l.efrom as lkp_efrom,\r         l.class as lkp_class,\r         l.subclass as lkp_subclass,\r         l.value as lkp_value,\r         l.contact_point_extra_info as lkp_contact_point_extra_info,\r         row_number() over (partition by cus.customer_number order by last_action_date desc) row_number\r from\r         work_cards_orig_staging cus,\r         client_alias ca,\r         locator l\r where       cus.customer_number = ca.source_client_ref (+)\r and     cus.customer_number is not null\r and     ca.source_type (+) = 0\r and     ca.eto (+) is null\r and     l.clid (+) = ca.clid\r and     l.eto (+) is null\r and     l.source_type (+) = 0\r and     l.class (+) = 402\r and     l.subclass (+) = 417\r union\r select /*+ parallel(cus) parallel(ca) parallel(l) use_hash(cus ca l) */\r         ca.clid AS clid,\r         ca.merge_clid AS merge_clid,\r         400 as class,\r         414 as subclass,\r         ltrim(rtrim(cus.telephone_number)) as value,\r         l.clid as lkp_clid,\r         l.efrom as lkp_efrom,\r         l.class as lkp_class,\r         l.subclass as lkp_subclass,\r         l.value as lkp_value,\r         l.contact_point_extra_info as lkp_contact_point_extra_info,\r         row_number() over (partition by cus.customer_number order by last_action_date desc) row_number\r from\r         work_cards_orig_staging cus,\r         client_alias ca,\r         locator l\r where       cus.customer_number = ca.source_client_ref (+)\r and     cus.customer_number is not null\r and     ca.source_type (+) = 0\r and     ca.eto (+) is null\r and     l.clid (+) = ca.clid\r and     l.eto (+) is null\r and     l.source_type (+) = 0\r and     l.class (+) = 400\r and     l.subclass (+) = 414\r )\r where row_number=1"
