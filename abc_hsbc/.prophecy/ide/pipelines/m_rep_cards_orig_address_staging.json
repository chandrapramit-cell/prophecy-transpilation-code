    "SQ_WORK_CARDSORIG_CUST_ADD_PAF" : {
      "id" : "SQ_WORK_CARDSORIG_CUST_ADD_PAF",
      "component" : "SQLStatement",
      "metadata" : {
        "label" : "SQ_WORK_CARDSORIG_CUST_ADD_PAF",
        "x" : 20,
        "y" : 220,
        "phase" : 1
      },
      "properties" : {
        "fileTabs" : [ {
          "path" : "out0",
          "id" : "out0",
          "language" : "sql",
          "content" : "select /*+ parallel(paf) parallel(r) parallel(ca) parallel(a) use_hash(paf r ca a) */\r        distinct r.adid,\r        paf.paf_out1,\r        paf.paf_out2,\r        paf.paf_out3,\r        paf.paf_out4,\r        paf.paf_out5,\r        paf.paf_out6,\r        paf.paf_out10,\r        paf.paf_pafstate,\r        paf.paf_area,\r        paf.paf_district,\r        paf.paf_sector,\r        paf.paf_unit,\r        paf.paf_dps,\r        paf.paf_xcoordinate,\r        paf.paf_ycoordinate\r from work_cardsorig_cust_add_paf paf,\r      resides r,\r      client_alias ca,\r      address a\r where ltrim(rtrim(ca.source_client_ref(+))) = ltrim(rtrim(paf.customer_number))\r and   ca.source_type (+) = 0\r and   ca.source_system_code (+) = 'U'\r and   ca.class (+) = '585'\r and   ca.clid = r.clid (+)\r and   r.eto (+) is null\r and   r.source_type(+) = 0\r and   r.adid = a.adid (+)\r and a.eto (+) is null\r and\r         (nvl(a.line1,'#') != nvl(paf.paf_out1,'#')\r         or\r         nvl(a.line2,'#') != nvl(paf.paf_out2,'#')\r         or\r         nvl(a.line3,'#') != nvl(paf.paf_out3,'#')\r         or\r         nvl(a.line4,'#') != nvl(paf.paf_out4,'#')\r         or\r         nvl(a.line5,'#') != nvl(paf.paf_out5,'#')\r         or\r         nvl(a.postcode,'#') != upper(nvl(nvl(paf.paf_out6,paf.paf_out10),'#'))\r         or\r         nvl(a.area,'#') != nvl(paf.paf_area,'#')\r         or\r         nvl(a.district,'#') != nvl(paf.paf_district,'#')\r         or\r         nvl(a.sector,'#') != nvl(paf.paf_sector,'#')\r         or\r         nvl(a.unit,'#') != nvl(paf.paf_unit,'#')\r         or\r         nvl(a.dps,'#') != nvl(paf.paf_dps,'#')\r         or\r         nvl(a.pafstate,'#') != nvl(paf.paf_pafstate,'#')\r         or\r         nvl(a.xcoordinate,99999999) != nvl(paf.paf_xcoordinate,99999999)\r         or\r         nvl(a.ycoordinate,99999999) != nvl(paf.paf_ycoordinate,99999999))"
        } ]
      },
