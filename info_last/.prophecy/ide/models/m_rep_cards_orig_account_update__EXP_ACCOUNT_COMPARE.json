          "content" : "select  \r /*+ parallel(wrk) parallel(aa) parallel(a) parallel(ca)  use_hash(wrk aa a ca) */ \r *  from \r (\r select \r        aa.accid as account_alias_accid,\r        a.accid as account_accid,\r        ca.clid,\r        ca.merge_clid,\r \t   wrk.application_number,\r \t   wrk.product,\r \t   wrk.application_source_code,\r \t   wrk.application_status,\r \t   wrk.last_action_date,\r        wrk.application_store_number,\r \t   a.acc_type,\r \t   a.source_code,\r \t   a.status,\r \t   a.status_date,\r        a.date_last_acc_status_change,\r        a.domicile_branch,\r \t   row_number() over (partition by wrk.application_number order by wrk.last_action_date desc) row_number\r from  work_cards_orig_staging wrk,\r       account_alias aa,\r \t  account a,\r \t  client_alias ca\r where wrk.application_number = aa.account_alias_id (+)\r and   aa.source_system_code (+) = 'U'\r and   aa.eto (+) is null\r and   aa.accid = a.accid (+)\r and   wrk.customer_number = ca.source_client_ref (+)\r and   ca.source_system_code (+) = 'U'\r and   ca.source_type (+) = 0\r and  ca.class (+)  = '585'\r and   ca.eto (+) is null\r )\r where row_number=1"
